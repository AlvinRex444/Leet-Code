class Solution {
    public int removeElement(int[] nums, int val) 
    {
        int ln=nums.length;
        int l=0,r=0;
        while(l<ln)
        {
            if(nums[l]!=val)
            {
                nums[r]=nums[l];
                r++;
            }
            l++;
        }
        return r;
    }
}
